# Copy this file to .env and fill in values. .env is gitignored — never commit real keys.
# In production (Vercel/Render), set these in the host's Environment Variables dashboard.

# ── Supabase auth (frontend) ──────────────────────────────────────────────
# From your Supabase project: Settings → API.
# These are PUBLIC (shipped in the browser bundle) — the anon key is safe to expose.
# Auth stays DORMANT until BOTH are set: the app runs open to everyone without them.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase service-role key (server only, for verifying tokens / admin tasks).
# SECRET — never prefix with VITE_ and never expose to the browser. Optional until
# you enable backend auth enforcement.
SUPABASE_SERVICE_ROLE_KEY=

# ── Backend ───────────────────────────────────────────────────────────────
PORT=3016
ANTHROPIC_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
